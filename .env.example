# =============================================================================
#  realtime-crypto-pipeline — environment variables
#  Copy this file to `.env` and adjust as needed. Never commit `.env`.
# =============================================================================

# ----- Producer ---------------------------------------------------------------
# Comma-separated CoinGecko coin IDs to track.
# Lookup: https://api.coingecko.com/api/v3/coins/list
COINS=bitcoin,ethereum,solana,cardano,polkadot,ripple,dogecoin,avalanche-2,chainlink,polygon

# How often the producer polls the CoinGecko API (seconds).
POLL_INTERVAL_SECONDS=30

# CoinGecko base URL. Override if you have a Pro key.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# ----- Kafka ------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=crypto.prices.raw
KAFKA_TOPIC_AGG=crypto.prices.minute
KAFKA_CLIENT_ID=crypto-producer
KAFKA_REPLICATION_FACTOR=1

# ----- Spark ------------------------------------------------------------------
SPARK_MASTER=local[2]
SPARK_CHECKPOINT_DIR=/opt/spark/checkpoints
SPARK_LOG_LEVEL=WARN

# ----- PostgreSQL -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crypto
POSTGRES_USER=crypto
POSTGRES_PASSWORD=crypto
POSTGRES_SCHEMA=public

# ----- Airflow ----------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow

# ----- Dashboard --------------------------------------------------------------
DASHBOARD_PORT=8501
DASHBOARD_REFRESH_SECONDS=10
